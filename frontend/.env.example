# URL do backend hospedado (Railway, Render, Fly.io, etc.)
# Em desenvolvimento local, não é necessário — usa http://localhost:8000 por padrão.
# No Vercel, configure ambas as variáveis nas Environment Variables do projeto.

NEXT_PUBLIC_API_URL=https://your-backend.railway.app
NEXT_PUBLIC_BACKEND_URL=https://your-backend.railway.app
